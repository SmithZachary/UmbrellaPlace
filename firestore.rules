rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin UIDs — only these users can read/update data
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == "xUWUFpdXeDSJxZIAgVwy5F5eyEs1" ||
        request.auth.uid == "ut9PhvrCWNS8NvxqOAy5mWirCfB2"
      );
    }

    // Inquiries created server-side via submitInquiry function (admin SDK bypasses rules)
    // Only admins can read and update from client
    match /inquiries/{docId} {
      allow create: if false;
      allow read, update: if isAdmin();
      allow delete: if false;
    }

    // Email thread subcollection — admins only
    match /inquiries/{docId}/emails/{emailId} {
      allow read, write: if isAdmin();
    }

    // Social agent posts — admins only
    match /social-posts/{docId} {
      allow read, write: if isAdmin();
    }

    // Agent configuration — admins only
    match /agent-config/{docId} {
      allow read, write: if isAdmin();
    }

    // Agent activity logs — admins only
    match /agent-activity/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Scout opportunities — admins only
    match /scout-opportunities/{docId} {
      allow read, write: if isAdmin();
    }

    // Engagement drafts — admins only
    match /engagement-drafts/{docId} {
      allow read, write: if isAdmin();
    }

    // Messenger conversations — admins only
    match /messenger-conversations/{docId} {
      allow read, write: if isAdmin();
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
